
# MPCPCTWEBAPP — ENV TEMPLATE (SAFE TO COMMIT)
############################################

########################
# Runtime
########################
NODE_ENV=development
# Dev-only: test login 9876543210 / 123456 (off in production unless true)
ENABLE_TEST_BYPASS_LOGIN=true

########################
# Database
########################
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@HOST/DBNAME?retryWrites=true&w=majority

########################
# Auth (JWT cookie + Google OAuth)
########################
# IMPORTANT: set a strong random secret in production
JWT_SECRET=please_change_me
NEXTAUTH_SECRET=please_change_me_same_as_jwt_or_separate
NEXTAUTH_URL=https://yourdomain.com
# Google OAuth (login + signup — same button flow)
# 1. Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# 2. Authorized redirect URI (must match exactly):
#    https://yourdomain.com/api/auth/google/callback
#    http://localhost:3000/api/auth/google/callback   (local dev)
# 3. Authorized JavaScript origins: https://yourdomain.com , http://localhost:3000
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: used by /api/seed-admin in this repo
SEED_TOKEN=dev-seed-token-please-change

# Optional: forces secure cookie behind certain proxies
NEXT_PUBLIC_FORCE_SECURE_COOKIE=false

# Optional: allow GET /api/debug in production (default off)
ENABLE_DEBUG_API=false

# Protect GET /api/check-env in production (?token=...)
CHECK_ENV_TOKEN=change-me-before-production

# Comma-separated browser origins for Socket.IO (custom server.js). Falls back to NEXT_PUBLIC_SITE_URL.
SOCKET_IO_ALLOWED_ORIGINS=https://yourdomain.com

########################
# Admin defaults (seeded)
########################
# In production, ADMIN_PHONE and ADMIN_PASSWORD are required for /api/admin/login bootstrap.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=Admin@1234
ADMIN_STATE=NA
ADMIN_CITY=NA

########################
# Site / SEO / Analytics
########################
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

########################
# Email (SMTP) — used for emails/notifications
########################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=no-reply@yourdomain.com

########################
# Payments (Razorpay)
########################
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

########################
# Cloudinary (optional: profile images)
########################
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

########################
# Phone OTP — Firebase (MongoDB remains primary database)
########################
# Client (browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server — Firebase Admin SDK (verify ID token after OTP)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste private key with literal \n for newlines
FIREBASE_PRIVATE_KEY=

########################
# Video Learning (filesystem storage)
########################
# Linux (KVM): /var/www/videos
# Windows dev example: D:\\mpcpct_videos
VIDEO_STORAGE_PATH=/var/www/videos
SOLUTION_VIDEO_STORAGE_PATH=/var/www/videos/solutions

# Optional: max upload size in bytes (default ~1GB)
VIDEO_MAX_BYTES=1073741824
############################################